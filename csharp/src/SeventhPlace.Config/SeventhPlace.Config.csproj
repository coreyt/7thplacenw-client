<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>SeventhPlace.Config</RootNamespace>
    <PackageId>SeventhPlace.Config</PackageId>
    <Version>0.1.0</Version>
    <Description>Cross-platform Layered Configuration Manager</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="8.0.*" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="8.0.*" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="8.0.*" />
    <PackageReference Include="Microsoft.Extensions.Configuration.CommandLine" Version="8.0.*" />
    <PackageReference Include="System.ComponentModel.Annotations" Version="5.0.*" />
  </ItemGroup>

</Project>
